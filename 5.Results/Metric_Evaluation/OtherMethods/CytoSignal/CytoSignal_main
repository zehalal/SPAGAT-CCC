get_script_dir <- function() {
  cmd_args <- commandArgs(trailingOnly = FALSE)
  file_arg <- "--file="
  script_path <- NULL
  if (any(grepl(file_arg, cmd_args))) {
    script_path <- sub(file_arg, "", cmd_args[grep(file_arg, cmd_args)[1]])
  } else if (!is.null(sys.frames()[[1]]$ofile)) {
    script_path <- sys.frames()[[1]]$ofile
  } else if (requireNamespace("rstudioapi", quietly = TRUE) && rstudioapi::isAvailable()) {
    script_path <- rstudioapi::getActiveDocumentContext()$path
  } else {
    script_path <- getwd()
  }
  dirname(normalizePath(script_path, winslash = "/", mustWork = FALSE))
}

find_repo_root <- function(start_dir, target_file, max_up = 6) {
  cur <- normalizePath(start_dir, winslash = "/", mustWork = FALSE)
  for (i in seq_len(max_up)) {
    candidate <- file.path(cur, target_file)
    if (file.exists(candidate)) return(dirname(candidate))
    parent <- dirname(cur)
    if (identical(parent, cur)) break
    cur <- parent
  }
  stop("Cannot locate ", target_file, " from ", start_dir)
}

