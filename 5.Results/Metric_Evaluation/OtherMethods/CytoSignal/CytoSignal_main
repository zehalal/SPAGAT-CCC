clean_intr_db <- function(db) {
  for (slot in c("ligands", "receptors", "combined")) {
    fac <- db[[slot]]
    # drop entries with missing names to avoid NA propagation in checkIntr
    fac <- fac[!is.na(names(fac))]
    fac <- droplevels(fac)
    db[[slot]] <- fac
  }
  db
}
