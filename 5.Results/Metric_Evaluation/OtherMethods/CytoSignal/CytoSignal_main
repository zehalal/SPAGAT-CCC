# diffusion interaction
construct_result <- function(object, slot.use, combo_lookup){
  
  get_imputation_name <- function(slot.use){
    if (grepl('^diffusion', slot.use)) return('diffusion')
    if (grepl('^contact', slot.use)) return('contact')
    return('Raw')
  }
  imp_name <- get_imputation_name(slot.use)
  weight_graph <- object@imputation[[imp_name]]
  if (is.null(weight_graph) && !is.null(object@imputation$GauEps)) {
    weight_graph <- object@imputation$GauEps
  }
  if (is.null(weight_graph)) {
    stop(sprintf('Imputation graph for slot %s is missing.', slot.use))
  }
  weight <- weight_graph@nn.graph %>% as.matrix(.)
  rownames(weight) <- colnames(weight)
  
  lrscore.obj <- object@lrscore[[slot.use]]
  receiver_id <- lrscore.obj@res.list$result.hq
  if (is.null(receiver_id) || length(receiver_id) == 0) {
    receiver_id <- lrscore.obj@res.list$result
  }
  score <- lrscore.obj@score
  
  res_all <- list()
  
  for (i in names(receiver_id)){
    if (!(i %in% colnames(score))) next
    lr_row <- combo_lookup[combo_lookup$cpi_cc_id == i, , drop = FALSE]
    if (nrow(lr_row) == 0) next

    receiver_id_i = receiver_id[[i]]
    weight_i = weight[,receiver_id_i]
    score_i = score[receiver_id_i,i]
    
    weight_i <- as.data.frame(weight_i)
    weight_i <- weight_i %>% 
      rownames_to_column(var = "Sender")
    long_weight_i <- weight_i %>% 
      pivot_longer(
        cols = -Sender,            
        names_to = "Receiver",     
        values_to = "weight"      
      )
    
    long_weight_i <- long_weight_i[long_weight_i$weight!=0,]
    if (is.numeric(receiver_id_i)) {
      receiver_names <- colnames(weight)[receiver_id_i]
    } else {
      receiver_names <- as.character(receiver_id_i)
    }
    score_map <- rep(0, nrow(long_weight_i))
    match_idx <- match(long_weight_i$Receiver, receiver_names)
    valid_idx <- !is.na(match_idx)
    if (any(valid_idx)) {
      score_map[valid_idx] <- as.numeric(score_i[match_idx[valid_idx]])
    }
    long_weight_i$score <- score_map
    long_weight_i$sender_type <- cluster[long_weight_i$Sender]
    long_weight_i$receiver_type <- cluster[long_weight_i$Receiver]
    long_weight_i$Ligand <- lr_row$Ligand[1]
    long_weight_i$Receptor <- lr_row$Receptor[1]
    
    res_i <- long_weight_i[,c("sender_type", "receiver_type", "Ligand", "Receptor", "score")]
    colnames(res_i) <- c('Sender','Receiver',"Ligand","Receptor",'LRscore')
    res_i$all <- paste(res_i$Sender, res_i$Ligand, res_i$Receiver, res_i$Receptor, sep = '_')
    
    res_i_avg <- res_i %>%
      group_by(all) %>%                   
      summarise(
        Sender = first(Sender),               
        Receiver = first(Receiver),           
        Ligand = first(Ligand),               
        Receptor = first(Receptor),           
        LRscore = mean(LRscore, na.rm = TRUE) 
      )
    
    res_i_avg <- as.data.frame(res_i_avg)
    res_i_avg <- res_i_avg[,c(2,3,4,5,6,1)]
    res_all[[i]] <- res_i_avg
    
  }
  
  res_all <- do.call("rbind", res_all)
  res_all
  
  
}

